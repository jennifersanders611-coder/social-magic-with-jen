---
// Static thank-you / form-success page — no server-side data needed.
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Thank You | Social Magic with Jen</title>
<meta name="robots" content="noindex, nofollow">
<link rel="canonical" href="https://socialmagicwithjen.com/thank-you/">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:wght@600;700&family=Poppins:wght@300;400;500&family=Caveat:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #faf7f2;
    --plum: #4e3a5a;
    --plum-soft: #6b5380;
    --coral: #f26b6b;
    --coral-deep: #e1504f;
    --teal: #5fa8a8;
    --gold: #d9a441;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--cream);
    font-family: 'Poppins', sans-serif;
    color: var(--plum);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  .card {
    max-width: 520px;
    text-align: center;
  }
  .sparkle {
    width: 48px; height: 48px; color: var(--gold); margin: 0 auto 20px; display: block;
  }
  h1 {
    font-family: 'Lora', serif;
    font-size: 2.1rem;
    margin-bottom: 16px;
    line-height: 1.25;
  }
  p {
    font-size: 1.08rem;
    color: var(--plum-soft);
    margin-bottom: 28px;
    line-height: 1.7;
  }
  .script { font-family: 'Caveat', cursive; font-size: 1.3rem; color: var(--teal); display: block; margin-bottom: 24px; }
  a.btn {
    display: inline-block;
    background: var(--coral);
    color: var(--cream);
    padding: 14px 30px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  a.btn:hover { background: var(--coral-deep); transform: translateY(-2px); }
</style>
</head>
<body>
  <div class="card">
    <svg class="sparkle" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c.6 4.8 2 8 4.8 9.6 1.2.7 2.4 1.1 3.6 1.4-1.2.3-2.4.7-3.6 1.4C14 14 12.6 17.2 12 22c-.6-4.8-2-8-4.8-9.6C6 11.7 4.8 11.3 3.6 11c1.2-.3 2.4-.7 3.6-1.4C10 8 11.4 4.8 12 0z"/></svg>
    <h1>Your story just landed in my inbox.</h1>
    <span class="script">and I couldn't be more excited to read it</span>
    <p>Thanks for reaching out. I read every message myself, and I'll be in touch personally within 1&ndash;2 business days.</p>
    <a href="/" class="btn">Back to the homepage</a>
  </div>
</body>
</html>
