---
import Layout from '../layouts/Layout.astro';

// This page has no server-side data or props — it's a static marketing page.
---
<Layout
  title="Social Magic with Jen | Marketing Strategy for Women Entrepreneurs"
  description="Social Magic with Jen helps women-owned service businesses build AI-powered marketing systems that sound like them — not everyone else. Discover the Brand MAGIC Method."
  keywords="marketing strategy for women entrepreneurs, AI marketing for small business, brand voice guide, women-owned business marketing, Brand MAGIC Method, marketing system for coaches, marketing for solo founders"
  canonical="https://socialmagicwithjen.com/"
  ogDescription="Build a marketing system that sounds like you, not everyone else. Social Magic with Jen helps women-owned service businesses use AI to amplify their voice — not replace it."
  ogImage="https://socialmagicwithjen.com/images/jen-portrait.jpg"
  ogImageWidth="1279"
  ogImageHeight="1600"
>
  <Fragment slot="head">
<script type="application/ld+json">
