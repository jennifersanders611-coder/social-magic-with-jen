      ],
      "image": "https://socialmagicwithjen.com/images/jen-portrait.jpg",
      "knowsAbout": [
        "Marketing strategy for women entrepreneurs",
        "AI marketing systems",
        "Brand voice development",
        "Content strategy",
        "Marketing for small business",
        "AI workflow consulting"
      ]
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://socialmagicwithjen.com/#business",
      "name": "Social Magic with Jen",
      "founder": { "@id": "https://socialmagicwithjen.com/#jen" },
      "url": "https://socialmagicwithjen.com",
      "logo": "https://socialmagicwithjen.com/favicon-192.png",
      "image": "https://socialmagicwithjen.com/images/jen-portrait.jpg",
      "description": "Social Magic with Jen helps women-owned service businesses and solo founders build AI-powered marketing systems that sound like them — not everyone else. Services include the Brand MAGIC Method, brand voice development, AI workspace setup, and content strategy.",
      "slogan": "Marketing that sounds like you, not everyone else.",
      "areaServed": "Worldwide",
      "serviceType": [
        "Marketing strategy for women entrepreneurs",
        "AI marketing system setup",
        "Brand voice guide development",
        "Content strategy",
        "Marketing coaching for small business"
      ],
      "audience": {
        "@type": "Audience",
        "audienceType": "Women-owned service businesses, solo founders, coaches, consultants"
      },
      "sameAs": [
        "https://www.instagram.com/socialmagicwithjen/",
        "https://www.linkedin.com/in/jenniferlsanders",
        "https://www.facebook.com/socialmagicwithjen/"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "jen@socialmagicwithjen.com",
        "contactType": "customer service"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://socialmagicwithjen.com/#website",
      "url": "https://socialmagicwithjen.com",
      "name": "Social Magic with Jen",
      "description": "Marketing strategy and AI systems for women-owned service businesses",
      "publisher": { "@id": "https://socialmagicwithjen.com/#business" }
    }
  ]
}
</script>
  </Fragment>

  <style>
  .sparkle { display: inline-block; position: relative; width: 1em; height: 1em; }
  .sparkle svg { width: 100%; height: 100%; display: block; }

  .reveal-word { position: relative; display: inline-block; color: var(--coral-deep); font-style: italic; }
  .reveal-word .sparkle {
    position: absolute; top: -0.55em; right: -0.7em; width: 0.55em; height: 0.55em; color: var(--gold);
    animation: twinkle 2.6s ease-in-out infinite;
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.4; transform: scale(0.85) rotate(0deg); }
    50% { opacity: 1; transform: scale(1.05) rotate(8deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-word .sparkle { animation: none; }
    html { scroll-behavior: auto; }
  }

  nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(78, 58, 90, 0.08);
  }
  nav .wrap { display: flex; align-items: center; justify-content: space-between; height: 84px; gap: 16px; }
  .logo { font-family: 'Lora', serif; font-weight: 700; font-size: 1.5rem; color: var(--plum); display: flex; align-items: baseline; gap: 8px; flex-shrink: 0; }
  .logo .magic-word { color: var(--coral); }
  .logo .with-jen { font-family: 'Caveat', cursive; font-weight: 600; font-size: 1.1rem; color: var(--gold); }

  .nav-links { display: flex; gap: 28px; font-size: 0.92rem; font-weight: 500; color: var(--plum); }
  .nav-links a { position: relative; padding: 4px 0; }
  .nav-links a::after {
    content: ''; position: absolute; left: 0; bottom: -2px; width: 0; height: 2px;
    background: var(--coral); transition: width 0.25s ease;
  }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    background: var(--coral); color: var(--cream); padding: 11px 24px; border-radius: 999px;
    font-weight: 600; font-size: 0.9rem; transition: transform 0.2s ease, background 0.2s ease; white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-cta:hover { background: var(--coral-deep); transform: translateY(-1px); }

  .nav-toggle {
    display: none; flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px;
    background: rgba(78,58,90,0.06); border: none; cursor: pointer;
    align-items: center; justify-content: center; padding: 0;
  }
  .nav-toggle:focus-visible { outline: 2px solid var(--coral); outline-offset: 2px; }
  .nav-toggle svg { width: 20px; height: 20px; color: var(--plum); }
  .nav-toggle .icon-close { display: none; }
  nav.menu-open .nav-toggle .icon-open { display: none; }
  nav.menu-open .nav-toggle .icon-close { display: block; }

  .nav-mobile-panel {
    display: none; flex-direction: column; gap: 4px;
    padding: 8px 32px 20px; border-top: 1px solid rgba(78,58,90,0.08);
  }
  .nav-mobile-panel a {
    padding: 13px 4px; font-size: 1rem; font-weight: 500; color: var(--plum);
    border-bottom: 1px solid rgba(78,58,90,0.06);
  }
  .nav-mobile-panel a:last-child {
    border-bottom: none; color: var(--coral-deep); font-weight: 600;
  }
  nav.menu-open .nav-mobile-panel { display: flex; }

  @media (max-width: 880px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
    .nav-cta { display: none; }
    nav .wrap { height: 72px; }
  }
  @media (min-width: 881px) {
    .nav-mobile-panel { display: none !important; }
  }

  .btn-primary {
    background: var(--coral); color: var(--cream); padding: 16px 32px; border-radius: 999px;
    font-weight: 600; font-size: 1rem; display: inline-flex; align-items: center; gap: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 8px 24px rgba(242, 107, 107, 0.28); border: none; cursor: pointer; font-family: 'Poppins', sans-serif;
  }
  .btn-primary:hover { background: var(--coral-deep); transform: translateY(-2px); box-shadow: 0 12px 28px rgba(242,107,107,0.35); }

  .btn-secondary {
    font-weight: 500; color: var(--plum); border-bottom: 1.5px solid var(--plum); padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-secondary:hover { color: var(--coral-deep); border-color: var(--coral-deep); }

  section { padding: 100px 0; position: relative; }
  .section-eyebrow { font-family: 'Caveat', cursive; font-size: 1.3rem; color: var(--coral); display: block; margin-bottom: 8px; }
  .section-head { max-width: 640px; margin-bottom: 56px; }
  .section-head h2 { font-size: clamp(1.9rem, 3vw, 2.5rem); }
  .section-head p { color: var(--plum-soft); font-size: 1.08rem; margin-top: 16px; }
  .section-head.center { margin: 0 auto 56px; text-align: center; }

  .hero { padding: 100px 0 0; }
  .hero .wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center; }
  .eyebrow-tag { font-family: 'Caveat', cursive; font-size: 1.4rem; color: var(--gold); margin-bottom: 6px; display: block; }
  .hero h1 { font-size: clamp(2.3rem, 4vw, 3.4rem); margin-bottom: 26px; letter-spacing: -0.01em; }
  .hero-sub { font-size: 1.15rem; color: var(--plum-soft); max-width: 480px; margin-bottom: 36px; }
  .hero-ctas { display: flex; gap: 18px; flex-wrap: wrap; align-items: center; }

  .hero-visual { position: relative; height: 480px; }
  .note-card { position: absolute; width: 280px; background: white; border-radius: 18px; padding: 26px 26px 22px; box-shadow: 0 18px 40px rgba(78, 58, 90, 0.14); }
  .note-card.back { top: 0; left: 0; transform: rotate(-6deg); background: var(--plum); color: var(--cream); }
  .note-card.back .note-label { color: rgba(250,247,242,0.6); }
  .note-card.front { top: 200px; left: 150px; transform: rotate(4deg); border: 1.5px solid rgba(78,58,90,0.08); }
  .note-label { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; color: var(--coral); margin-bottom: 10px; display: block; }
  .note-card p { font-size: 1.02rem; line-height: 1.5; }
  .note-card.front p { color: var(--ink); }
  .note-card .script-tag { margin-top: 14px; font-size: 1.3rem; color: var(--teal); }
  .hero-sparkle-big { position: absolute; top: -10px; right: 10px; width: 46px; height: 46px; color: var(--gold); animation: twinkle 3.2s ease-in-out infinite; }

  @media (max-width: 880px) {
    .hero .wrap { grid-template-columns: 1fr; }
    .hero { padding: 64px 0 0; }
    .hero-visual { height: 400px; margin-top: 20px; }
    .note-card { width: 230px; }
    .note-card.front { left: 90px; top: 170px; }
  }

  .cred-bar { background: var(--plum); padding: 22px 0; margin-top: 70px; }
  .cred-bar .wrap { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; text-align: center; }
  .cred-item { color: rgba(250,247,242,0.92); font-size: 0.92rem; font-weight: 500; letter-spacing: 0.01em; }
  .cred-dot { color: var(--gold); font-size: 0.7rem; }
  @media (max-width: 700px) { .cred-bar .wrap { gap: 10px; } .cred-item { font-size: 0.82rem; } }

  .intro-photo { background: var(--cream); padding: 80px 0; }
  .intro-photo .wrap { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 48px; align-items: center; }
  .intro-photo-frame { border-radius: 22px; overflow: hidden; box-shadow: 0 18px 40px rgba(78,58,90,0.14); }
  .intro-photo-frame img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/5; }
  .intro-photo-copy .script { font-size: 1.4rem; color: var(--coral); display: block; margin-bottom: 10px; }
  .intro-photo-copy p { font-size: 1.1rem; color: var(--plum-soft); }
  @media (max-width: 880px) {
    .intro-photo .wrap { grid-template-columns: 1fr; }
    .intro-photo-frame { max-width: 280px; margin: 0 auto; }
  }

  .belief { background: var(--cream); }
  .belief-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px; }
  .belief-card { background: white; border-radius: 20px; padding: 36px 30px; box-shadow: 0 10px 30px rgba(78,58,90,0.06); border: 1px solid rgba(78,58,90,0.06); transition: transform 0.25s ease, box-shadow 0.25s ease; }
  .belief-card:hover { transform: translateY(-6px); box-shadow: 0 16px 36px rgba(78,58,90,0.1); }
  .belief-card .sparkle { width: 1.6rem; height: 1.6rem; color: var(--gold); margin-bottom: 16px; }
  .belief-card h3 { font-size: 1.2rem; margin-bottom: 10px; }
  .belief-card p { color: var(--plum-soft); font-size: 0.98rem; }
  @media (max-width: 880px) { .belief-row { grid-template-columns: 1fr; } }

  .problem { background: var(--plum); color: var(--cream); }
  .problem .section-head p { color: rgba(250,247,242,0.78); }
  .problem .section-eyebrow { color: var(--gold); }
  .problem h2 { color: var(--cream); }
  .problem-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 40px; max-width: 760px; }
  .problem-list li { list-style: none; display: flex; gap: 14px; font-size: 1.02rem; color: rgba(250,247,242,0.92); align-items: flex-start; }
  .problem-list .sparkle { flex-shrink: 0; margin-top: 4px; color: var(--coral); width: 0.85em; height: 0.85em; }
  @media (max-width: 700px) { .problem-list { grid-template-columns: 1fr; } }

  .audit-cta { background: var(--cream); padding: 56px 24px; text-align: center; border-bottom: 1px solid rgba(78,58,90,0.06); }
  .audit-cta .section-eyebrow { display: block; }
  .audit-cta h3 { font-family: 'Lora', serif; font-size: clamp(1.3rem, 2.8vw, 1.7rem); color: var(--plum); margin: 6px 0 22px; max-width: 560px; margin-left: auto; margin-right: auto; }

  .why-me { background: white; }
  .why-me-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .why-me-card { background: var(--cream); border-radius: 20px; padding: 32px 30px; border: 1px solid rgba(78,58,90,0.06); }
  .why-me-card p { color: var(--plum-soft); font-size: 1.02rem; margin-bottom: 12px; }
  .why-me-card p:last-child { margin-bottom: 0; }
  .why-me-card .lead { color: var(--ink); font-weight: 400; }
  .skill-stack { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .skill-pill { background: rgba(95,168,168,0.12); border: 1px solid rgba(95,168,168,0.3); color: var(--teal); padding: 8px 16px; border-radius: 999px; font-size: 0.88rem; font-weight: 500; }
  @media (max-width: 880px) { .why-me-layout { grid-template-columns: 1fr; } }

  .method { background: var(--cream); }
  .method-layout { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: center; }
  .method-photo { border-radius: 22px; overflow: hidden; box-shadow: 0 20px 44px rgba(78,58,90,0.14); position: relative; }
  .method-photo img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/5; }
  .method-photo-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 22px; background: linear-gradient(to top, rgba(78,58,90,0.85), transparent); color: var(--cream); font-family: 'Caveat', cursive; font-size: 1.2rem; }
  .method-steps { display: flex; flex-direction: column; gap: 28px; }
  .method-step { display: flex; gap: 20px; }
  .method-step .step-mark { width: 52px; height: 52px; border-radius: 50%; background: var(--plum); color: var(--cream); font-family: 'Lora', serif; font-weight: 700; font-size: 0.95rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .method-step h3 { font-size: 1.15rem; margin-bottom: 6px; }
  .method-step p { color: var(--plum-soft); font-size: 0.97rem; }
  @media (max-width: 880px) { .method-layout { grid-template-columns: 1fr; } .method-photo img { aspect-ratio: 16/10; } }

  .system { background: var(--cream); }
  .system-intro { max-width: 680px; margin: 0 auto 56px; text-align: center; }
  .system-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .system-card { background: white; border-radius: 20px; padding: 30px 28px; box-shadow: 0 10px 30px rgba(78,58,90,0.06); border: 1px solid rgba(78,58,90,0.06); display: flex; gap: 16px; align-items: flex-start; transition: transform 0.25s ease, box-shadow 0.25s ease; }
  .system-card:hover { transform: translateY(-4px); box-shadow: 0 14px 32px rgba(78,58,90,0.09); }
  .system-card .sparkle { flex-shrink: 0; width: 1.4rem; height: 1.4rem; color: var(--gold); margin-top: 4px; }
  .system-card h3 { font-size: 1.05rem; margin-bottom: 6px; }
  .system-card p { color: var(--plum-soft); font-size: 0.95rem; }
  .system-footer { text-align: center; margin-top: 48px; font-family: 'Caveat', cursive; font-size: 1.3rem; color: var(--plum); }
  @media (max-width: 760px) { .system-grid { grid-template-columns: 1fr; } }

  .walkaway { background: var(--plum); color: var(--cream); }
  .walkaway .section-eyebrow { color: var(--gold); }
  .walkaway h2 { color: var(--cream); }
  .walkaway .section-head p { color: rgba(250,247,242,0.78); }
  .walkaway-intro { max-width: 680px; margin: 0 auto 56px; text-align: center; }
  .walkaway-intro h2 { color: var(--cream); font-size: clamp(1.9rem, 3vw, 2.5rem); margin-bottom: 16px; }
  .walkaway-intro p { color: rgba(250,247,242,0.78); font-size: 1.08rem; }
  .walkaway-intro .section-eyebrow { color: var(--gold); }
  .walkaway-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 48px; }
  .walkaway-item { background: rgba(250,247,242,0.06); border: 1px solid rgba(250,247,242,0.14); border-radius: 16px; padding: 26px 24px; display: flex; gap: 16px; align-items: flex-start; }
  .walkaway-item .item-icon { font-size: 1.6rem; flex-shrink: 0; line-height: 1; }
  .walkaway-item h3 { color: var(--cream); font-size: 1.05rem; margin-bottom: 6px; }
  .walkaway-item p { color: rgba(250,247,242,0.75); font-size: 0.93rem; }
  .walkaway-footer { text-align: center; background: rgba(250,247,242,0.06); border: 1px solid rgba(250,247,242,0.14); border-radius: 18px; padding: 32px 36px; max-width: 760px; margin: 0 auto; color: rgba(250,247,242,0.88); font-size: 1.02rem; line-height: 1.7; }
  @media (max-width: 760px) { .walkaway-grid { grid-template-columns: 1fr; } }

  .fit { background: var(--cream); }
  .fit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .fit-card { border-radius: 20px; padding: 40px 36px; }
  .fit-card.yes { background: rgba(95,168,168,0.12); border: 1.5px solid rgba(95,168,168,0.3); }
  .fit-card.no { background: rgba(78,58,90,0.04); border: 1.5px solid rgba(78,58,90,0.1); }
  .fit-card h3 { font-size: 1.3rem; margin-bottom: 22px; }
  .fit-card.yes h3 { color: var(--teal); }
  .fit-card.no h3 { color: var(--plum-soft); }
  .fit-card ul { list-style: none; }
  .fit-card li { display: flex; gap: 12px; margin-bottom: 16px; font-size: 1rem; color: var(--ink); align-items: flex-start; }
  .fit-card .mark { flex-shrink: 0; font-weight: 700; margin-top: 1px; }
  .fit-card.yes .mark { color: var(--teal); }
  .fit-card.no .mark { color: var(--coral); }
  .fit-tagline { text-align: center; margin-top: 48px; font-family: 'Caveat', cursive; font-size: 1.6rem; color: var(--plum); }
  @media (max-width: 760px) { .fit-grid { grid-template-columns: 1fr; } }

  .founder { background: white; }
  .founder .wrap { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 56px; align-items: center; }
  .founder-portrait { width: 100%; border-radius: 24px; position: relative; overflow: hidden; box-shadow: 0 20px 44px rgba(78,58,90,0.16); }
  .founder-portrait img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/5; }
  .founder-portrait .sparkle { position: absolute; bottom: 18px; right: 18px; width: 2.1rem; height: 2.1rem; color: var(--gold); filter: drop-shadow(0 2px 6px rgba(0,0,0,0.25)); }
  .founder-copy .section-eyebrow { margin-bottom: 4px; }
  .founder-copy h2 { margin-bottom: 18px; }
  .founder-copy p { color: var(--plum-soft); font-size: 1.05rem; margin-bottom: 16px; max-width: 580px; }
  .founder-copy p.standout { color: var(--plum); font-style: italic; font-family: 'Lora', serif; font-size: 1.15rem; border-left: 3px solid var(--coral); padding-left: 18px; margin: 24px 0; }
  .founder-social { display: flex; gap: 18px; margin-top: 24px; }
  .founder-social a { width: 42px; height: 42px; border-radius: 50%; background: rgba(78,58,90,0.06); display: flex; align-items: center; justify-content: center; color: var(--plum); transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease; }
  .founder-social a:hover { background: var(--coral); color: var(--cream); transform: translateY(-2px); }
  .founder-social svg { width: 19px; height: 19px; }
  @media (max-width: 880px) { .founder .wrap { grid-template-columns: 1fr; } .founder-portrait { max-width: 320px; margin: 0 auto; } }

  .testimonials { background: var(--cream); }
  .testimonial-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .testimonial-card { background: white; border-radius: 22px; padding: 40px 38px; box-shadow: 0 10px 30px rgba(78,58,90,0.07); border: 1px solid rgba(78,58,90,0.06); position: relative; }
  .testimonial-card .sparkle { width: 2rem; height: 2rem; color: var(--gold); margin-bottom: 18px; display: block; }
  .testimonial-headline { font-family: 'Lora', serif; font-size: 1.15rem; color: var(--plum); margin-bottom: 14px; font-weight: 600; }
  .testimonial-card p.body { color: var(--ink); font-size: 1rem; margin-bottom: 22px; }
  .testimonial-attrib .name { font-weight: 600; color: var(--plum); font-size: 0.95rem; }
  .testimonial-attrib .role { color: var(--plum-soft); font-size: 0.85rem; }
  @media (max-width: 760px) { .testimonial-grid { grid-template-columns: 1fr; } }

  .faq { background: white; }
  .brand-story { background: var(--plum); color: var(--cream); }
  .brand-story .wrap { max-width: 760px; }
  .brand-story .section-eyebrow { color: var(--gold); }
  .brand-story h2 { color: var(--cream); font-size: clamp(1.9rem, 3vw, 2.5rem); margin-bottom: 32px; }
  .brand-story p { color: rgba(250,247,242,0.85); font-size: 1.08rem; margin-bottom: 20px; max-width: 680px; }
  .brand-story p:last-of-type { margin-bottom: 0; }
