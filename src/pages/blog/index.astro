---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
);

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Layout
  title="Blog | Social Magic with Jen"
  description="Marketing insights, brand storytelling tips, and AI guidance for small business owners who want to show up with clarity and confidence."
  canonical="https://socialmagicwithjen.com/blog/"
>
  <style>
    
    nav { position: sticky; top: 0; z-index: 50; background: rgba(250,247,242,0.92); backdrop-filter: blur(6px); border-bottom: 1px solid rgba(78,58,90,0.08); }
    nav .wrap { display: flex; align-items: center; justify-content: space-between; height: 84px; gap: 16px; }
    .logo { font-family: 'Lora', serif; font-weight: 700; font-size: 1.5rem; color: var(--plum); display: flex; align-items: baseline; gap: 8px; flex-shrink: 0; }
    .logo .magic-word { color: var(--coral); }
    .logo .with-jen { font-family: 'Caveat', cursive; font-weight: 600; font-size: 1.1rem; color: var(--gold); }
    .nav-links { display: flex; gap: 28px; font-size: 0.92rem; font-weight: 500; color: var(--plum); }
    .nav-links a { position: relative; padding: 4px 0; }
    .nav-links a::after { content: ''; position: absolute; left: 0; bottom: -2px; width: 0; height: 2px; background: var(--coral); transition: width 0.25s ease; }
    .nav-links a:hover::after { width: 100%; }
    .nav-cta { background: var(--coral); color: var(--cream); padding: 11px 24px; border-radius: 999px; font-weight: 600; font-size: 0.9rem; transition: transform 0.2s ease, background 0.2s ease; white-space: nowrap; flex-shrink: 0; }
    .nav-cta:hover { background: var(--coral-deep); transform: translateY(-1px); }

    .blog-hero { background-color: var(--plum); color: var(--cream); padding: 5rem 1.5rem 4.5rem; text-align: center; }
    .accent-label { font-family: 'Caveat', cursive; font-size: 1.3rem; color: var(--coral); display: block; margin-bottom: 0.5rem; }
    .blog-hero h1 { font-family: 'Lora', serif; font-size: clamp(2rem, 5vw, 3rem); color: var(--cream); margin: 0 auto 1.25rem; max-width: 700px; line-height: 1.2; }
    .hero-sub { font-family: 'Poppins', sans-serif; font-size: 1.05rem; color: rgba(250,247,242,0.82); max-width: 560px; margin: 0 auto; line-height: 1.75; }

    .blog-list { padding: 5rem 1.5rem; background-color: var(--cream); }
    .empty-state { text-align: center; font-family: 'Poppins', sans-serif; color: var(--plum); font-size: 1.1rem; padding: 4rem 0; }
    .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem; }

    .post-card { background: #fff; border-radius: 18px; overflow: hidden; box-shadow: 0 2px 14px rgba(78,58,90,0.07); display: flex; flex-direction: column; transition: transform 0.22s ease, box-shadow 0.22s ease; }
    .post-card:hover { transform: translateY(-5px); box-shadow: 0 10px 28px rgba(78,58,90,0.13); }
    .card-body { padding: 1.75rem; display: flex; flex-direction: column; flex: 1; }
    .tag-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.85rem; }
    .tag { font-family: 'Poppins', sans-serif; font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--teal); background: rgba(95,168,168,0.1); padding: 0.28rem 0.65rem; border-radius: 100px; }
    .card-title { font-family: 'Lora', serif; font-size: 1.2rem; line-height: 1.4; margin: 0 0 0.75rem; }
    .card-title a { color: var(--plum); text-decoration: none; transition: color 0.18s ease; }
    .card-title a:hover { color: var(--coral); }
    .card-description { font-family: 'Poppins', sans-serif; font-size: 0.9rem; color: #5a5a5a; line-height: 1.65; flex: 1; margin: 0 0 1.1rem; }
    .card-meta { font-family: 'Poppins', sans-serif; font-size: 0.78rem; color: #999; margin-bottom: 1.1rem; }
    .meta-sep { margin: 0 0.4rem; }
    .read-more { font-family: 'Poppins', sans-serif; font-size: 0.875rem; font-weight: 600; color: var(--coral); text-decoration: none; align-self: flex-start; transition: color 0.18s ease; }
    .read-more:hover { color: var(--plum); }

    .blog-cta { background-color: var(--plum); padding: 5rem 1.5rem; text-align: center; }
    .blog-cta-inner { max-width: 640px; margin: 0 auto; }
    .blog-cta .accent-label { color: var(--gold); }
    .blog-cta h2 { font-family: 'Lora', serif; font-size: clamp(1.6rem, 3.5vw, 2.2rem); color: var(--cream); margin: 0 auto 1rem; line-height: 1.3; }
    .blog-cta p { font-family: 'Poppins', sans-serif; font-size: 1rem; color: rgba(250,247,242,0.8); line-height: 1.75; margin: 0 auto 2rem; }
    .cta-button { display: inline-block; background-color: var(--coral); color: #fff; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.95rem; padding: 0.85rem 2rem; border-radius: 100px; text-decoration: none; transition: background-color 0.2s ease, transform 0.2s ease; }
    .cta-button:hover { background-color: var(--coral-deep); transform: translateY(-2px); }

    footer { background: var(--cream); padding: 48px 0 40px; border-top: 1px solid rgba(78,58,90,0.08); }
    footer .wrap { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
    .footer-links { display: flex; gap: 24px; font-size: 0.9rem; color: var(--plum-soft); }
    .footer-links a:hover { color: var(--coral); }
    .footer-bottom { border-top: 1px solid rgba(78,58,90,0.08); margin-top: 32px; padding-top: 24px; text-align: center; font-size: 0.82rem; color: var(--plum-soft); width: 100%; }

    @media (max-width: 600px) {
      .post-grid { grid-template-columns: 1fr; }
      .blog-hero { padding: 4rem 1.25rem 3.5rem; }
      .blog-list { padding: 3.5rem 1.25rem; }
      .nav-links { display: none; }
    }
  
  </style>



<nav>
  <div class="wrap">
    <a href="/" class="logo">Social<span class="magic-word">Magic</span><span class="with-jen">with jen</span></a>
    <div class="nav-links">
      <a href="/#method">The Method</a>
      <a href="/#fit">Is This You?</a>
      <a href="/#about">About Jen</a>
      <a href="/#faq">FAQ</a>
      <a href="/blog">Blog</a>
    </div>
    <a href="/#contact" class="nav-cta">Let's Get Started</a>
  </div>
</nav>

<section class="blog-hero">
  <div class="wrap">
    <span class="accent-label">The Blog</span>
    <h1>Stories, Strategies &amp; a Little Magic</h1>
    <p class="hero-sub">Practical marketing insights for small business owners who want to show up with clarity, consistency, and a voice that sounds like them.</p>
  </div>
</section>

<section class="blog-list">
  <div class="wrap">
    {posts.length === 0 ? (
      <p class="empty-state">New posts are on their way. Check back soon!</p>
    ) : (
      <div class="post-grid">
        {posts.map((post) => (
          <article class="post-card">
            <div class="card-body">
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="tag-row">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              <h2 class="card-title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="card-description">{post.data.description}</p>
              <div class="card-meta">
                <time datetime={new Date(post.data.publishDate).toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
                <span class="meta-sep">·</span>
                <span>{post.data.author}</span>
              </div>
              <a href={`/blog/${post.id}`} class="read-more">Read the post →</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<section class="blog-cta">
  <div class="blog-cta-inner">
    <span class="accent-label">Ready to go deeper?</span>
    <h2>Let's build your marketing system together.</h2>
    <p>The Brand MAGIC Method is a step-by-step process to uncover your story, find your voice, and teach AI how to amplify it.</p>
    <a href="/#contact" class="cta-button">Start the Conversation</a>
  </div>
</section>

<footer>
  <div class="wrap">
    <a href="/" class="logo">Social<span class="magic-word">Magic</span><span class="with-jen">with jen</span></a>
    <div class="footer-links">
      <a href="/#method">The Method</a>
      <a href="/#fit">Is This You?</a>
      <a href="/blog">Blog</a>
      <a href="/resources">Resources</a>
      <a href="/#contact">Let's Get Started</a>
    </div>
  </div>
  <div class="wrap footer-bottom">
    &copy; 2026 Social Magic with Jen. All rights reserved.
  </div>
</footer>


</Layout>
