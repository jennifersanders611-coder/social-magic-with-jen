---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Blog | Social Magic with Jen"
  description="Marketing insights, brand storytelling tips, and AI guidance for small business owners who want to show up with clarity and confidence."
>
  <!-- Blog Hero -->
  <section class="blog-hero">
    <div class="container">
      <span class="accent-label">The Blog</span>
      <h1>Stories, Strategies &amp; a Little Magic</h1>
      <p class="hero-sub">
        Practical marketing insights for small business owners who want to show up
        with clarity, consistency, and a voice that sounds like them.
      </p>
    </div>
  </section>

  <!-- Post Grid -->
  <section class="blog-list">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty-state">New posts are on their way. Check back soon!</p>
      ) : (
        <div class="post-grid">
          {posts.map((post) => (
            <article class="post-card">
              {post.data.image && (
                <a href={`/blog/${post.slug}`} class="card-image-link" tabindex="-1" aria-hidden="true">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt ?? post.data.title}
                    class="card-image"
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                </a>
              )}
              <div class="card-body">
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="tag-row" aria-label="Post categories">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 class="card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p class="card-description">{post.data.description}</p>
                <div class="card-meta">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  <span class="meta-sep" aria-hidden="true">·</span>
                  <span>{post.data.author}</span>
                </div>
                
                  href={`/blog/${post.slug}`}
                  class="read-more"
                  aria-label={`Read: ${post.data.title}`}
                >
                  Read the post →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="blog-cta">
    <div class="container blog-cta-inner">
      <span class="accent-label">Ready to go deeper?</span>
      <h2>Let's build your marketing system together.</h2>
      <p>The Brand MAGIC Method is a step-by-step process to uncover your story, find your voice, and teach AI how to amplify it.</p>
      <a href="/#contact" class="cta-button">Start the Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background-color: var(--color-plum);
    color: var(--color-cream);
    padding: 5rem 1.5rem 4.5rem;
    text-align: center;
  }

  .accent-label {
    font-family: 'Caveat', cursive;
    font-size: 1.3rem;
    color: var(--color-coral);
    display: block;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .blog-hero h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-cream);
    margin: 0 auto 1.25rem;
    max-width: 700px;
    line-height: 1.2;
  }

  .hero-sub {
    font-family: 'Poppins', sans-serif;
    font-size: 1.05rem;
    color: rgba(250, 247, 242, 0.82);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.75;
  }

  .blog-list {
    padding: 5rem 1.5rem;
    background-color: var(--color-cream);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .empty-state {
    text-align: center;
    font-family: 'Poppins', sans-serif;
    color: var(--color-plum);
    font-size: 1.1rem;
    padding: 4rem 0;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .post-card {
    background: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 14px rgba(78, 58, 90, 0.07);
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 28px rgba(78, 58, 90, 0.13);
  }

  .card-image-link {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: rgba(95, 168, 168, 0.12);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.32s ease;
  }

  .post-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tag-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }

  .tag {
    font-family: 'Poppins', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-teal);
    background: rgba(95, 168, 168, 0.1);
    padding: 0.28rem 0.65rem;
    border-radius: 100px;
  }

  .card-title {
    font-family: 'Lora', serif;
    font-size: 1.2rem;
    line-height: 1.4;
    margin: 0 0 0.75rem;
  }

  .card-title a {
    color: var(--color-plum);
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .card-title a:hover {
    color: var(--color-coral);
  }

  .card-description {
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    color: #5a5a5a;
    line-height: 1.65;
    flex: 1;
    margin: 0 0 1.1rem;
  }

  .card-meta {
    font-family: 'Poppins', sans-serif;
    font-size: 0.78rem;
    color: #999;
    margin-bottom: 1.1rem;
  }

  .meta-sep {
    margin: 0 0.4rem;
  }

  .read-more {
    font-family: 'Poppins', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-coral);
    text-decoration: none;
    align-self: flex-start;
    transition: color 0.18s ease;
  }

  .read-more:hover {
    color: var(--color-plum);
  }

  .blog-cta {
    background-color: var(--color-plum);
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .blog-cta-inner {
    max-width: 640px;
  }

  .blog-cta .accent-label {
    color: var(--color-ochre);
  }

  .blog-cta h2 {
    font-family: 'Lora',
