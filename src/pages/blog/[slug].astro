---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.publishDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "url": "https://socialmagicwithjen.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Social Magic with Jen",
    "url": "https://socialmagicwithjen.com"
  },
  "keywords": post.data.tags?.join(', '),
  "image": post.data.image ?? "https://socialmagicwithjen.com/og-default.jpg"
};
---

<BaseLayout
  title={`${post.data.title} | Social Magic with Jen`}
  description={post.data.description}
>
  <!-- Schema markup for Google + AI search -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  {post.data.image && (
    <div class="post-hero-image">
      <img
        src={post.data.image}
        alt={post.data.imageAlt ?? post.data.title}
        width="1200"
        height="630"
        loading="eager"
      />
    </div>
  )}

  <article class="post-article">
    <div class="post-container">

      <header class="post-header">
        <a href="/blog" class="back-link">← Back to Blog</a>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="tag-row" aria-label="Post categories">
            {post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        <div class="post-meta">
          <span>By {post.data.author}</span>
          <span class="meta-sep" aria-hidden="true">·</span>
          <time datetime={post.data.publishDate.toISOString()}>
            {formatDate(post.data.publishDate)}
          </time>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-link">← Back to Blog</a>
        <a href="/#contact" class="cta-button">Start the Conversation</a>
      </footer>

    </div>
  </article>

  <section class="post-cta-band">
    <div class="post-cta-inner">
      <span class="cta-accent">Every business has a story worth sharing.</span>
      <p>Let's uncover yours and build a marketing system that sounds like you — not like everyone else.</p>
      <a href="/#contact" class="cta-button-light">Work With Jen</a>
    </div>
  </section>
</BaseLayout>

<style>
  .post-hero-image {
    width: 100%;
    max-height: 500px;
    overflow: hidden;
    background-color: rgba(78, 58, 90, 0.08);
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-article {
    background-color: var(--color-cream);
    padding: 4.5rem 1.5rem 5rem;
  }

  .post-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    font-family: 'Poppins', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-teal);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.18s ease;
  }

  .back-link:hover {
    color: var(--color-plum);
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(78, 58, 90, 0.1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .post-header .back-link {
    margin-bottom: 1.75rem;
  }

  .tag-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-family: 'Poppins', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-teal);
    background: rgba(95, 168, 168, 0.1);
    padding: 0.28rem 0.65rem;
    border-radius: 100px;
  }

  .post-title {
    font-family: 'Lora', serif;
